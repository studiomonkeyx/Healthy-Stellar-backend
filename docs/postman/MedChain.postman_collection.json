        "type": "text/javascript",
        "exec": [
          "// Collection-level tests",
          "pm.test('Status code is not 5xx', function () {",
          "    pm.expect(pm.response.code).to.not.be.oneOf([500, 501, 502, 503, 504, 505]);",
          "});",
          "",
          "pm.test('Response time is less than 1000ms', function () {",
          "    pm.expect(pm.response.responseTime).to.be.below(1000);",
          "});",
          "",
          "pm.test('Response has required fields', function () {",
          "    const jsonData = pm.response.json();",
          "    if (jsonData && typeof jsonData === 'object') {",
          "        // Check for common required fields based on endpoint",
          "        if (pm.request.url.path.includes('auth/login') && pm.response.code === 200) {",
          "            pm.expect(jsonData).to.have.property('tokens');",
          "            pm.expect(jsonData.tokens).to.have.property('accessToken');",
          "        }",
          "        if (pm.request.url.path.includes('records') && pm.response.code === 200) {",
          "            // Records endpoints should return data",
          "            pm.expect(jsonData).to.be.an('object');",
          "        }",
          "    }",
          "});"
        ]
      }
    }
  ],
